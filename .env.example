# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sxsw_zine?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/sxsw_zine?schema=public"

# local uses checked-in sample photos and does not require AWS credentials.
# Use s3 in production.
STORAGE_TYPE="local"

# Required for click tracking. Use a long random value locally and in production.
IP_HASH_SALT="replace-with-a-long-random-local-secret"

# Required when STORAGE_TYPE=s3
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME="sxsw-zine-bucket"
AWS_CLOUDFRONT_DOMAIN="https://d2qb1jexhp0efc.cloudfront.net"
NEXT_PUBLIC_AWS_CLOUDFRONT_DOMAIN="https://d2qb1jexhp0efc.cloudfront.net"
